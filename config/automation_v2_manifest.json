{
  "version": "2.0.0",
  "timezone": "Australia/Brisbane",
  "policy": {
    "single_owner_per_function": true,
    "no_popup": true,
    "task_scheduler_primary_for_local_loops": true,
    "openclaw_cron_for_orchestration_only": true
  },
  "delegation_chain": {
    "commander": "Oragorn",
    "prime_agents": {
      "Frodex": "Operations",
      "Quandalf": "Strategy",
      "Balrog": "Security (pending)",
      "Smaug": "Trading (pending)"
    },
    "transport": "Logron"
  },
  "tasks": [
    {
      "name": "oragorn-context-sync-daily",
      "owner": "Oragorn",
      "type": "task",
      "schedule": {
        "kind": "daily",
        "times": [
          "03:00"
        ]
      },
      "command": "powershell -NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File scripts/automation/run-oragorn-context-sync.ps1",
      "legacy_task_name": "AutoQuant-Oragorn-ContextSync"
    },
    {
      "name": "frodex-ops-loop-15m",
      "owner": "Frodex",
      "type": "task",
      "schedule": {
        "kind": "interval",
        "minutes": 15
      },
      "command": "powershell -NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File scripts/automation/run_autopilot_task.ps1",
      "legacy_task_name": "AutoQuant-autopilot-user"
    },
    {
      "name": "frodex-bundle-log-15m",
      "owner": "Logron",
      "type": "task",
      "schedule": {
        "kind": "interval",
        "minutes": 15
      },
      "command": "powershell -NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File scripts/automation/bundle-run-log.ps1 -Pipeline frodex -WindowMinutes 16",
      "legacy_task_name": "AutoQuant-bundle-run-log-user"
    },
    {
      "name": "quandalf-bundle-log-2h",
      "owner": "Logron",
      "type": "task",
      "schedule": {
        "kind": "interval",
        "hours": 2
      },
      "command": "powershell -NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File scripts/automation/bundle-run-log.ps1 -Pipeline quandalf -WindowMinutes 130",
      "legacy_task_name": "AutoQuant-bundle-run-log-quandalf-user"
    },
    {
      "name": "frodex-youtube-watch-6h",
      "owner": "Frodex",
      "type": "task",
      "schedule": {
        "kind": "daily",
        "times": [
          "00:00",
          "02:00",
          "04:00",
          "06:00",
          "08:00",
          "10:00",
          "12:00",
          "14:00",
          "16:00",
          "18:00",
          "20:00",
          "22:00"
        ]
      },
      "command": "powershell -NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File scripts/pipeline/run_youtube_watch_worker.ps1",
      "legacy_task_name": "AutoQuant-youtube-watch-user"
    },
    {
      "name": "quandalf-research-4h",
      "owner": "Quandalf",
      "type": "task",
      "schedule": {
        "kind": "daily",
        "times": [
          "02:00",
          "06:00",
          "10:00",
          "14:00",
          "18:00",
          "22:00"
        ]
      },
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/claude-tasks/run-strategy-researcher.ps1",
      "legacy_task_name": "AutoQuant-Claude-Researcher"
    },
    {
      "name": "quandalf-generate-2h",
      "owner": "Quandalf",
      "type": "task",
      "schedule": {
        "kind": "daily",
        "times": [
          "01:00",
          "03:00",
          "05:00",
          "07:00",
          "09:00",
          "11:00",
          "13:00",
          "15:00",
          "17:00",
          "19:00",
          "21:00",
          "23:00"
        ]
      },
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/claude-tasks/run-strategy-generator.ps1",
      "legacy_task_name": "AutoQuant-Claude-Generator"
    },
    {
      "name": "quandalf-doctrine-daily-0400",
      "owner": "Quandalf",
      "type": "task",
      "schedule": {
        "kind": "daily",
        "times": [
          "04:00"
        ]
      },
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/claude-tasks/run-doctrine-synthesizer.ps1",
      "legacy_task_name": "AutoQuant-Claude-Doctrine"
    },
    {
      "name": "quandalf-auditor-daily-0500",
      "owner": "Quandalf",
      "type": "task",
      "schedule": {
        "kind": "daily",
        "times": [
          "05:00"
        ]
      },
      "command": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/claude-tasks/run-backtest-auditor.ps1",
      "legacy_task_name": "AutoQuant-Claude-Auditor"
    },
    {
      "name": "frodex-daily-intel-0530",
      "owner": "Frodex",
      "type": "task",
      "schedule": {
        "kind": "daily",
        "times": [
          "05:30"
        ]
      },
      "command": "powershell -NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File scripts/automation/run_daily_intel.ps1",
      "legacy_task_name": "AutoQuant-daily-intel-user"
    },
    {
      "name": "frodex-transcript-ingest-0930",
      "owner": "Frodex",
      "type": "task",
      "schedule": {
        "kind": "daily",
        "times": [
          "00:10",
          "02:10",
          "04:10",
          "06:10",
          "08:10",
          "10:10",
          "12:10",
          "14:10",
          "16:10",
          "18:10",
          "20:10",
          "22:10"
        ]
      },
      "command": "powershell -NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -Command \"python scripts/pipeline/transcript_ingest_worker.py\"",
      "legacy_task_name": "AutoQuant-transcript-ingest-user"
    },
    {
      "name": "frodex-forward-runner-4h",
      "owner": "Frodex",
      "type": "task",
      "schedule": {
        "kind": "daily",
        "times": [
          "00:05",
          "04:05",
          "08:05",
          "12:05",
          "16:05",
          "20:05"
        ]
      },
      "command": "python scripts/forward/forward_runner.py",
      "legacy_task_name": "AutoQuant-Forward-Runner"
    },
    {
      "name": "frodex-forward-health-4h",
      "owner": "Frodex",
      "type": "task",
      "schedule": {
        "kind": "daily",
        "times": [
          "00:25",
          "04:25",
          "08:25",
          "12:25",
          "16:25",
          "20:25"
        ]
      },
      "command": "python scripts/forward/check_runner_health.py",
      "legacy_task_name": "AutoQuant-Forward-Health"
    },
    {
      "name": "frodex-forward-weekly-sun0700",
      "owner": "Frodex",
      "type": "task",
      "schedule": {
        "kind": "weekly",
        "days": [
          "Sunday"
        ],
        "time": "07:00"
      },
      "command": "python scripts/forward/generate_weekly_scorecard.py",
      "legacy_task_name": "AutoQuant-Forward-Weekly"
    }
  ],
  "cron_jobs": [
    {
      "name": "git-auto-sync",
      "owner": "Logron",
      "schedule": "*/30 * * * *",
      "notes": "repo sync/backup"
    },
    {
      "name": "quandalf-auto-execute",
      "owner": "Quandalf",
      "schedule": "*/30 * * * *",
      "notes": "strategy orchestration"
    },
    {
      "name": "research-digest-update",
      "owner": "Quandalf",
      "schedule": "0 */6 * * *",
      "notes": "digest refresh"
    },
    {
      "name": "keeper-daily-light",
      "owner": "Logron",
      "schedule": "30 5 * * *",
      "notes": "light maintenance"
    },
    {
      "name": "keeper-weekly-deep",
      "owner": "Logron",
      "schedule": "0 18 * * 0",
      "notes": "deep maintenance"
    }
  ]
}
