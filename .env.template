# Telegram routing (use YOUR chat IDs, not shown here)
# Get these from the bot's identity messages

# Log group: where backtest alerts + logging go
TELEGRAM_LOG_CHAT_ID=<log_group_id>

# Command channel: your DM with the bot
TELEGRAM_CMD_CHAT_ID=<dm_chat_id>

# Telegram bot token (NEVER commit; use .env.local or env vars)
# Get from BotFather
TELEGRAM_BOT_TOKEN=<your_bot_token>
