{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "quandalf/rule.schema.json",
  "title": "Quandalf Rule",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "type",
    "title",
    "status",
    "confidence",
    "evidence_paths",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "type": { "const": "rule" },
    "title": { "type": "string", "minLength": 3 },
    "status": { "type": "string", "enum": ["active", "review", "deprecated", "superseded"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_paths": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "supporting_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contradictory_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "superseded_by": {
      "type": "array",
      "items": { "type": "string" }
    },
    "updated_at": { "type": "string", "minLength": 10 },
    "validated_at": { "type": "string", "minLength": 10 }
  }
}