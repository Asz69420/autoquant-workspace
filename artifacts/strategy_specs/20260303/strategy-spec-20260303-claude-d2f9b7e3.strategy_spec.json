  "name": "KAMA Stochastic Adaptive Pullback",
  "created_at": "2026-03-03T13:14:00Z",
  "source": "claude-advisor",
  "edge_hypothesis": "KAMA (Kaufman Adaptive Moving Average) self-adapts smoothing speed — fast during trends, slow during ranges. This built-in adaptivity means it serves as BOTH trend direction AND implicit regime filter. When KAMA is trending (close above/below KAMA), Stochastic K crossing D from oversold/overbought zones identifies pullback completion — the moment momentum resumes in the trend direction. This bypasses the stochastic_reversal template bug (line 175, k_prev issue) by using spec_rules interpreter directly. The hypothesis: KAMA's adaptive smoothing produces fewer false trend signals than fixed-period EMA, while Stochastic pullback timing enters at better prices than crossover strategies.",
  "regime_assumption": "trending",
  "target_assets": ["ETH", "BTC"],
  "target_timeframes": ["4h"],
  "variants": [
    {
      "name": "kama_stoch_pullback_v1_8to1",
      "description": "Core thesis: KAMA trend + Stochastic oversold/overbought pullback. 8:1 R:R. Stochastic K must be in extreme zone (< 30 for long, > 70 for short) before crossing D.",
      "template_name": "spec_rules",
      "entry_long": [
        "close > KAMA_10_2_30",
        "STOCHk_14_3_3 crosses_above STOCHd_14_3_3",
        "STOCHk_14_3_3 < 30"
      ],
      "entry_short": [
