{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/indicator_record.schema.json",
  "title": "IndicatorRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "created_at",
    "tv_ref",
    "name",
    "key_inputs",
    "signals_described",
    "notes",
    "component_type",
    "pine_raw_bytes",
    "pine_raw_lines",
    "pine_min_bytes",
    "pine_min_lines",
    "pine_size_class",
    "pine_too_large",
    "sha256",
    "truncated"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "created_at": { "type": "string", "format": "date-time" },
    "tv_ref": { "type": "string", "minLength": 1, "maxLength": 2048 },
    "url": { "type": "string", "maxLength": 2048 },
    "name": { "type": "string", "minLength": 1, "maxLength": 300 },
    "author": { "type": "string", "maxLength": 200 },
    "version": { "type": "string", "maxLength": 64 },
    "key_inputs": {
      "type": "array",
      "maxItems": 30,
      "items": { "type": "string", "maxLength": 200 }
    },
    "signals_described": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "maxLength": 300 }
    },
    "notes": {
      "type": "array",
      "maxItems": 10,
      "items": { "type": "string", "maxLength": 500 }
    },
    "source_pointer": { "type": "string", "maxLength": 1024 },
    "source_min_pointer": { "type": "string", "maxLength": 1024 },
    "component_type": { "type": "string", "enum": ["INDICATOR", "STRATEGY"] },
    "pine_raw_bytes": { "type": "integer", "minimum": 0 },
    "pine_raw_lines": { "type": "integer", "minimum": 0 },
    "pine_min_bytes": { "type": "integer", "minimum": 0 },
    "pine_min_lines": { "type": "integer", "minimum": 0 },
    "pine_size_class": { "type": "string", "enum": ["small", "medium", "large"] },
    "pine_too_large": { "type": "boolean" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "truncated": { "type": "boolean" }
  },
  "allOf": [
    {
      "description": "IndicatorRecord JSON must be <= 60KB (enforced by emitter/verifier)."
    },
    {
      "description": "Pine source payload must be <= 200KB when stored externally (enforced by emitter/verifier)."
    }
  ]
}
