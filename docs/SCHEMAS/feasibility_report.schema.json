{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/feasibility_report.schema.json",
  "title": "FeasibilityReport",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "created_at", "inputs", "checks", "metrics", "verdict", "fail_reasons", "suggestion"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "created_at": { "type": "string", "format": "date-time" },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy_spec_path", "variant_name", "dataset_meta_path"],
      "properties": {
        "strategy_spec_path": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "variant_name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "dataset_meta_path": { "type": "string", "minLength": 1, "maxLength": 2048 }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["history_ok", "timeframe_ok", "signal_frequency_estimate_ok", "parameter_ranges_ok", "required_fields_ok"],
      "properties": {
        "history_ok": { "type": "boolean" },
        "timeframe_ok": { "type": "boolean" },
        "signal_frequency_estimate_ok": { "type": "boolean" },
        "parameter_ranges_ok": { "type": "boolean" },
        "required_fields_ok": { "type": "boolean" }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bars_available", "bars_required", "estimated_signal_count", "estimated_trades_min"],
      "properties": {
        "bars_available": { "type": "integer", "minimum": 0 },
        "bars_required": { "type": "integer", "minimum": 0 },
        "estimated_signal_count": {
          "type": "object",
          "additionalProperties": false,
          "required": ["long", "short", "total"],
          "properties": {
            "long": { "type": "integer", "minimum": 0 },
            "short": { "type": "integer", "minimum": 0 },
            "total": { "type": "integer", "minimum": 0 }
          }
        },
        "estimated_trades_min": { "type": "integer", "minimum": 0 }
      }
    },
    "verdict": { "type": "string", "enum": ["PASS", "FAIL"] },
    "fail_reasons": { "type": "array", "maxItems": 10, "items": { "type": "string", "maxLength": 160 } },
    "suggestion": { "type": "array", "maxItems": 5, "items": { "type": "string", "maxLength": 160 } }
  }
}
