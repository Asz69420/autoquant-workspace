{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/insight_card.schema.json",
  "title": "InsightCard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "created_at",
    "source",
    "title",
    "concept",
    "tags",
    "suggested_roles",
    "confidence",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "created_at": { "type": "string", "format": "date-time" },
    "source": { "const": "manual" },
    "title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "concept": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "tags": {
      "type": "array",
      "maxItems": 10,
      "items": { "type": "string", "minLength": 1, "maxLength": 64 }
    },
    "suggested_roles": {
      "type": "array",
      "maxItems": 6,
      "items": {
        "type": "string",
        "enum": ["trend", "entry", "exit", "confirmation", "regime_gate", "risk"]
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": { "type": "string", "enum": ["NEW", "PROCESSED"] }
  }
}
