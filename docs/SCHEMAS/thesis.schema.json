{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/thesis.schema.json",
  "title": "Thesis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "created_at",
    "inputs",
    "title",
    "thesis_bullets",
    "hypotheses",
    "candidate_signals",
    "required_data",
    "constraints",
    "tags",
    "sha256_inputs"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0", "1.1"] },
    "id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "created_at": { "type": "string", "format": "date-time" },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["research_card_paths", "indicator_record_paths", "linkmap_paths"],
      "properties": {
        "research_card_paths": { "type": "array", "maxItems": 5, "items": { "type": "string", "maxLength": 1024 } },
        "indicator_record_paths": { "type": "array", "maxItems": 10, "items": { "type": "string", "maxLength": 1024 } },
        "linkmap_paths": { "type": "array", "maxItems": 5, "items": { "type": "string", "maxLength": 1024 } }
      }
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "thesis_bullets": { "type": "array", "maxItems": 10, "items": { "type": "string", "maxLength": 400 } },
    "hypotheses": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["statement", "rationale", "falsifiable_test", "expected_regime", "failure_modes"],
        "properties": {
          "statement": { "type": "string", "minLength": 1, "maxLength": 300 },
          "rationale": { "type": "string", "minLength": 1, "maxLength": 500 },
          "falsifiable_test": { "type": "string", "minLength": 1, "maxLength": 500 },
          "expected_regime": { "type": "string", "minLength": 1, "maxLength": 120 },
          "failure_modes": { "type": "array", "maxItems": 5, "items": { "type": "string", "maxLength": 240 } }
        }
      }
    },
    "candidate_signals": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description", "uses_indicators", "confidence"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 120 },
          "description": { "type": "string", "minLength": 1, "maxLength": 300 },
          "uses_indicators": { "type": "array", "maxItems": 5, "items": { "type": "string", "maxLength": 120 } },
          "timeframe_bias": { "type": "string", "maxLength": 60 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "combo_proposals": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["indicator", "role", "description", "confidence"],
        "properties": {
          "indicator": { "type": "string", "minLength": 1, "maxLength": 120 },
          "role": { "type": "string", "enum": ["trend", "entry", "exit", "confirmation", "filter"] },
          "description": { "type": "string", "minLength": 1, "maxLength": 260 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "mutation_catalog": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "suggestion", "bounds"],
        "properties": {
          "type": { "type": "string", "enum": ["threshold", "risk", "execution", "filter"] },
          "suggestion": { "type": "string", "minLength": 1, "maxLength": 260 },
          "bounds": { "type": "string", "minLength": 1, "maxLength": 160 }
        }
      }
    },
    "required_data": { "type": "array", "maxItems": 10, "items": { "type": "string", "maxLength": 200 } },
    "constraints": { "type": "array", "maxItems": 10, "items": { "type": "string", "maxLength": 200 } },
    "tags": { "type": "array", "maxItems": 20, "items": { "type": "string", "maxLength": 60 } },
    "sha256_inputs": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
